# Force PHP 8.1 on Hostinger (change to 8.2 if available)
AddHandler application/x-httpd-php81 .php

# Block direct access to sensitive files
<FilesMatch "^\.env|\.env\..*|database\.sqlite">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block access to non-api PHP files from web
<FilesMatch "^(migrate)\.php$">
    Order allow,deny
    Deny from all
</FilesMatch>
